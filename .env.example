# -------------------------------------------------------------
# CONFIGURACIÓN DE ENTORNO - COTIONLINE
# Instrucciones: Copia este archivo y renombralo a ".env"
# -------------------------------------------------------------

PORT=3000

# [BASE DE DATOS]
# 1. Crea una base de datos vacía en tu MySQL local.
# 2. Configura los datos de acceso aquí abajo.
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD='tu_contraseña_aqui_si_tienes'
DB_NAME='tu_nombre_de_base_de_datos_aqui'

# Déjalo en "development" para que las tablas se creen automáticamente.
NODE_ENV=development

# [SECRETOS DE SEGURIDAD]
# Agrega aquí strings aleatorios.
JWT_SECRET='tu_secreto_jwt_aqui'
JWT_RECOVERY_SECRET='tu_secreto_recuperacion_aqui'

# [PASARELA DE PAGOS - WOMPI]
# Obtén tus llaves de prueba (sandbox) en el portal de Wompi.co.
WOMPI_PUBLIC_KEY='tu_llave_publica_wompi_aqui'
WOMPI_PRIVATE_KEY='tu_llave_privada_wompi_aqui'
WOMPI_INTEGRITY_SECRET='tu_secreto_integridad_wompi_aqui'
WOMPI_EVENTS_SECRET='tu_secreto_eventos_wompi_aqui'
WOMPI_CURRENCY=COP

# [SERVICIO DE CORREO - NODEMAILER]
# Crea una cuenta gratuita en Mailtrap.io para atrapar correos de prueba.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER='tu_usuario_mailtrap_aqui'
SMTP_PASS='tu_contraseña_mailtrap_aqui'

# [FRONTEND]
# Dirección donde corre tu aplicación de Angular localmente.
FRONTEND_URL='http://localhost:4200'
